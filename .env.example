# Township Configuration
DOMAIN=localhost
ADMIN_EMAIL=admin@localhost

# Database - CHANGE IN PRODUCTION
DB_USER=township
DB_PASSWORD=your-secure-database-password
DB_NAME=township_db
DB_PORT=5432

# Redis
REDIS_PORT=6379

# Security - CHANGE IN PRODUCTION
# Generate with: openssl rand -base64 32
SECRET_KEY=your-super-secret-key-change-me

# Initial Admin Account (bootstrap only — use Auth0 SSO for all logins after setup)
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_EMAIL=admin@yourdomain.com
INITIAL_ADMIN_PASSWORD=unused-after-auth0-is-configured

# Google Cloud (Optional - for AI features and Secret Manager)
GOOGLE_CLOUD_PROJECT=
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1

# Frontend
FRONTEND_PORT=5173
